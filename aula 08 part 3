        "def send_console_alert(message):\n",
        "    \"\"\"\n",
        "    Função auxiliar para disparar um alerta no console.\n",
        "    \"\"\"\n",
        "    print(f\"\\n!!! ALERTA CRÍTICO (Console) !!!\")\n",
        "    print(f\"Mensagem: {message}\")\n",
        "    print(f\"!!! FIM DO ALERTA !!!\\n\")\n",
        "\n",
        "def simulate_email_alert(recipient, subject, body):\n",
        "    \"\"\"\n",
        "    Função auxiliar para simular o envio de um e-mail de alerta.\n",
        "    Em um ambiente de produção, esta função usaria uma biblioteca de e-mail (ex: smtplib).\n",
