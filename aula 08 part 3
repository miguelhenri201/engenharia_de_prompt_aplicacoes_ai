        "\"\"\"\n",
        "Módulo de monitoramento e alertas do sistema.\n",
        "Funções auxiliares para verificação de condições críticas e notificações.\n",
        "\"\"\"\n",
        "\n",
        "from enum import Enum\n",
        "from datetime import datetime\n",
        "from typing import Callable, Optional, Dict, Any\n",
        "import logging\n",
        "\n",
        "# Configuração de logging\n",
        "logging.basicConfig(level=logging.INFO)\n",
        "logger = logging.getLogger(__name__)\n",
        "\n",
        "\n",
        "class AlertSeverity(Enum):\n",
        "    \"\"\"Níveis de severidade de alerta.\"\"\"\n",
        "    INFO = \"info\"\n",
        "    WARNING = \"warning\"\n",
        "    CRITICAL = \"critical\"\n",
        "\n",
        "\n",
        "class EmailConfig:\n",
        "    \"\"\"Configuração centralizada de email.\"\"\"\n",
        "    SMTP_HOST = \"smtp.example.com\"\n",
        "    SMTP_PORT = 587\n",
        "    FROM_ADDRESS = \"alerts@system.com\"\n",
        "    RETRY_ATTEMPTS = 3\n",
        "\n",
        "\n",
        "def check_critical_condition(\n",
        "    condition: bool,\n",
        "    condition_name: str,\n",
        "    on_critical: Optional[Callable] = None,\n",
        "    **context: Any\n",
        ") -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    Verifica uma condição crítica do sistema.\n",
        "\n",
        "    Args:\n",
        "        condition: A condição a ser verificada (True = crítica)\n",
        "        condition_name: Nome descritivo da condição\n",
        "        on_critical: Função callback executada se a condição for crítica\n",
        "        **context: Contexto adicional para logging\n",
        "\n",
        "    Returns:\n",
        "        Dicionário com status e detalhes da verificação\n",
        "    \"\"\"\n",
        "    result = {\n",
        "        \"condition_name\": condition_name,\n",
        "        \"is_critical\": condition,\n",
        "        \"timestamp\": datetime.now().isoformat(),\n",
        "        \"context\": context\n",
        "    }\n",
        "\n",
        "    if condition:\n",
        "        logger.warning(\n",
        "            f\"Condição crítica detectada: {condition_name}\",\n",
        "            extra={\"context\": context}\n",
        "        )\n",
        "\n",
        "        if on_critical:\n",
        "            try:\n",
        "                on_critical(**context)\n",
        "            except Exception as e:\n",
        "                logger.error(f\"Erro ao executar callback: {e}\")\n",
        "                result[\"callback_error\"] = str(e)\n",
        "\n",
        "    return result\n",
        "\n",
        "\n",
        "def simulate_email_alert(\n",
        "    recipient: str,\n",
        "    subject: str,\n",
        "    body: str,\n",
        "    severity: AlertSeverity = AlertSeverity.WARNING\n",
        ") -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    Simula o envio de um alerta por email.\n",
        "\n",
        "    Args:\n",
        "        recipient: Endereço de email do destinatário\n",
        "        subject: Assunto do email\n",
        "        body: Corpo da mensagem\n",
        "        severity: Nível de severidade do alerta\n",
        "\n",
        "    Returns:\n",
        "        Dicionário com status do envio\n",
        "    \"\"\"\n",
        "    email_data = {\n",
        "        \"from\": EmailConfig.FROM_ADDRESS,\n",
        "        \"to\": recipient,\n",
        "        \"subject\": f\"[{severity.value.upper()}] {subject}\",\n",
        "        \"body\": body,\n",
        "        \"severity\": severity.value,\n",
        "        \"timestamp\": datetime.now().isoformat(),\n",
        "        \"status\": \"sent\"\n",
        "    }\n",
        "\n",
        "    try:\n",
        "        # Validação básica\n",
        "        if not recipient or \"@\" not in recipient:\n",
        "            raise ValueError(f\"Email inválido: {recipient}\")\n",
        "\n",
        "        if not subject or not body:\n",
        "            raise ValueError(\"Assunto e corpo não podem estar vazios\")\n",
        "\n",
        "        # Simulação de envio\n",
        "        logger.info(\n",
        "            f\"Email enviado para {recipient}\",\n",
        "            extra={\"subject\": subject, \"severity\": severity.value}\n",
        "        )\n",
        "\n",
        "        return email_data\n",
        "\n",
        "    except Exception as e:\n",
        "        logger.error(f\"Erro ao enviar email: {e}\")\n",
        "        email_data[\"status\"] = \"failed\"\n",
        "        email_data[\"error\"] = str(e)\n",
        "        return email_data\n",
        "\n",
        "\n",
        "def monitor_system_health(\n",
        "    thresholds: Dict[str, float],\n",
        "    current_values: Dict[str, float],\n",
        "    alert_callback: Optional[Callable] = None\n",
        ") -> Dict[str, Any]:\n",
        "    \"\"\"\n",
        "    Monitora a saúde do sistema comparando valores com limites.\n",
        "\n",
        "    Args:\n",
        "        thresholds: Dicionário com limites aceitáveis\n",
        "        current_values: Dicionário com valores atuais\n",
        "        alert_callback: Função para enviar alertas\n",
        "\n",
        "    Returns:\n",
        "        Relatório de monitoramento\n",
        "    \"\"\"\n",
        "    violations = {}\n",
        "\n",
        "    for metric, threshold in thresholds.items():\n",
        "        current = current_values.get(metric, 0)\n",
        "\n",
        "        if current > threshold:\n",
        "            violations[metric] = {\n",
        "                \"current\": current,\n",
        "                \"threshold\": threshold,\n",
        "                \"exceeded_by\": current - threshold\n",
        "            }\n",
        "\n",
        "    report = {\n",
        "        \"timestamp\": datetime.now().isoformat(),\n",
        "        \"total_metrics\": len(thresholds),\n",
        "        \"violations_count\": len(violations),\n",
        "        \"violations\": violations,\n",
        "        \"status\": \"critical\" if violations else \"ok\"\n",
        "    }\n",
        "\n",
        "    if violations and alert_callback:\n",
        "        alert_callback(report)\n",
        "\n",
        "    return report\n",
        "\n",
        "\n",
        "# Exemplo de uso\n",
        "if __name__ == \"__main__\":\n",
        "    # Verificando condições críticas\n",
        "    result = check_critical_condition(\n",
        "        condition=True,\n",
        "        condition_name=\"CPU Usage High\",\n",
        "        cpu_usage=95.5,\n",
        "        threshold=80\n",
        "    )\n",
        "    print(\"Verificação crítica:\", result)\n",
        "\n",
        "    # Simulando alerta por email\n",
        "    email_result = simulate_email_alert(\n",
        "        recipient=\"admin@example.com\",\n",
        "        subject=\"Sistema com alto uso de CPU\",\n",
        "        body=\"O sistema está operando acima dos limites normais de CPU.\",\n",
        "        severity=AlertSeverity.CRITICAL\n",
        "    )\n",
        "    print(\"\\nEmail enviado:\", email_result)\n",
        "\n",
        "    # Monitoramento de saúde\n",
        "    health_report = monitor_system_health(\n",
        "        thresholds={\"cpu\": 80, \"memory\": 85, \"disk\": 90},\n",
        "        current_values={\"cpu\": 95, \"memory\": 60, \"disk\": 75}\n",
        "    )\n",
        "    print(\"\\nRelatório de saúde:\", health_report)"
