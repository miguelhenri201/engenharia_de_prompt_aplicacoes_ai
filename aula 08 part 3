        "    print(f\"Corpo:\\n{body}\")\n",
        "    print(f\"--- E-mail simulado enviado ---\\n\")\n",
        "\n",
        "def autonomous_alert_system(check_interval_seconds=5):\n",
        "    \"\"\"\n",
        "    Programa autônomo que verifica continuamente uma condição crítica\n",
        "    e dispara alertas quando necessário.\n",
        "    \"\"\"\n",
        "    print(\"Sistema de alerta autônomo iniciado. Pressione Ctrl+C para parar.\")\n",
        "    try:\n",
        "        while True:\n",
        "            if check_critical_condition():\n",
        "                alert_message = \"Condição crítica detectada! Ação imediata necessária.\"\n",
        "\n",
        "                # Disparar alerta no console\n",
        "                send_console_alert(alert_message)\n",
        "\n",
        "                # Simular envio de e-mail\n",
        "                simulate_email_alert(\n",
        "                    recipient=\"seu.email@exemplo.com\",\n",
        "                    subject=\"ALERTA CRÍTICO: [Sistema]\",\n",
        "                    body=f\"Prezado, uma condição crítica foi identificada no sistema.\\nDetalhes: {alert_message}\\nPor favor, verifique o status imediatamente.\"\n",
        "                )\n",
        "                # Opcional: Adicionar um atraso maior após um alerta para evitar spam\n",
        "                time.sleep(check_interval_seconds * 2)\n",
        "\n",
        "            time.sleep(check_interval_seconds)\n",
        "    except KeyboardInterrupt:\n",
        "        print(\"Sistema de alerta autônomo interrompido pelo usuário.\")\n",
        "\n",
