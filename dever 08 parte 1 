        "import os\n",
        "import shutil\n",
        "\n",
        "def organize_files(source_directory):\n",
        "    \"\"\"\n",
        "    Organiza arquivos em um diretório, movendo-os para subpastas\n",
        "    com base em suas extensões.\n",
        "\n",
        "    Args:\n",
        "        source_directory (str): O caminho do diretório a ser organizado.\n",
        "    \"\"\"\n",
        "    if not os.path.isdir(source_directory):\n",
        "        print(f\"Erro: O diretório de origem '{source_directory}' não existe.\")\n",
        "        return\n",
        "\n",
        "    print(f\"Iniciando a organização no diretório: {source_directory}\")\n",
        "\n",
        "    # Itera sobre todos os itens no diretório de origem\n",
        "    for filename in os.listdir(source_directory):\n",
        "        file_path = os.path.join(source_directory, filename)\n",
        "\n",
        "        # Ignora diretórios e links simbólicos\n",
        "        if os.path.isfile(file_path):\n",
        "            # Obtém o nome base do arquivo e sua extensão\n",
        "            name, extension = os.path.splitext(filename)\n",
        "\n",
        "            # Remove o ponto da extensão e a converte para minúsculas\n",
        "            # Se não houver extensão, usa 'outros'\n",
        "            if extension:\n",
        "                folder_name = extension[1:].lower() + 's' # Ex: .pdf -> pdfs\n",
        "            else:\n",
        "                folder_name = 'outros'\n",
        "\n",
        "            target_folder_path = os.path.join(source_directory, folder_name)\n",
        "\n",
        "            # Cria a pasta de destino se ela não existir\n",
        "            os.makedirs(target_folder_path, exist_ok=True)\n",
        "\n",
        "            # Move o arquivo para a pasta de destino\n",
        "            try:\n",
        "                shutil.move(file_path, target_folder_path)\n",
        "                print(f\"Movido '{filename}' para '{folder_name}'\")\n",
        "            except Exception as e:\n",
        "                print(f\"Erro ao mover '{filename}': {e}\")\n",
        "    print(\"Organização concluída!\")\n",
        "\n",
        "# --- Exemplo de Uso ---\n",
        "\n",
        "# 1. Defina o diretório que você deseja organizar.\n",
        "#    Por exemplo, um diretório dentro de '/content/' para o Colab.\n",
        "organizing_dir = '/content/meus_arquivos_baguncados'\n",
        "\n",
        "# Opcional: Criar alguns arquivos de teste para demonstração\n",
        "# Remova esta seção se você já tem arquivos para organizar\n",
        "print(f\"\\nCriando diretório e arquivos de teste em '{organizing_dir}'...\")\n",
        "os.makedirs(organizing_dir, exist_ok=True)\n",
        "\n",
        "# Lista de arquivos de teste para criar\n",
        "files_to_create = [\n",
        "    'documento.pdf',\n",
        "    'imagem_ferias.jpg',\n",
        "    'relatorio.docx',\n",
        "    'foto_perfil.png',\n",
        "    'planilha.xlsx',\n",
        "    'audio.mp3',\n",
        "    'video.mp4',\n",
        "    'outro_arquivo_sem_extensao'\n",
        "]\n",
        "\n",
        "for f_name in files_to_create:\n",
        "    with open(os.path.join(organizing_dir, f_name), 'w') as f:\n",
        "        f.write(f\"Conteúdo de {f_name}\")\n",
        "    print(f\"Criado: {f_name}\")\n",
        "\n",
        "print(\"Arquivos de teste criados. Agora vamos organizá-los!\")\n",
        "\n",
        "# 2. Chame a função para organizar os arquivos\n",
        "organize_files(organizing_dir)\n",
        "\n",
        "print(f\"\\nConteúdo final do diretório '{organizing_dir}':\")\n",
        "for root, dirs, files in os.walk(organizing_dir):\n",
        "    level = root.replace(organizing_dir, '').count(os.sep)\n",
        "    indent = ' ' * 4 * (level)\n",
        "    print(f'{indent}{os.path.basename(root)}/')\n",
        "    subindent = ' ' * 4 * (level + 1)\n",
        "    for f in files:\n",
        "        print(f'{subindent}{f}')\n"
