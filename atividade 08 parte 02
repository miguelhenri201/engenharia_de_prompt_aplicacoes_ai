        "import requests\n",
        "\n",
        "def consultar_cep_com_erro(cep):\n",
        "    \"\"\"\n",
        "    Consulta a API ViaCEP para obter informações de endereço,\n",
        "    mas com uma URL intencionalmente errada para provocar um erro.\n",
        "\n",
        "    Args:\n",
        "        cep (str): O CEP a ser consultado.\n",
        "\n",
        "    Returns:\n",
        "        dict or None: Um dicionário com os dados do endereço formatados,\n",
        "                      ou None se ocorrer um erro.\n",
        "    \"\"\"\n",
        "    # URL da API ViaCEP com um erro intencional (ex: 'wz' ao invés de 'ws')\n",
        "    url_errada = f\"https://viacep.com.br/wz/{cep}/json/\"\n",
        "\n",
        "    print(f\"Tentando consultar CEP '{cep}' com a URL intencionalmente errada: {url_errada}\")\n",
        "    try:\n",
        "        response = requests.get(url_errada, timeout=5) # Adiciona um timeout para evitar que a requisição demore indefinidamente\n",
        "\n",
        "        # Verifica se a requisição foi bem-sucedida (código 200)\n",
        "        if response.status_code == 200:\n",
        "            data = response.json()\n",
        "            if data.get('erro'):\n",
        "                print(f\"Erro: CEP '{cep}' não encontrado ou inválido na API (apesar de status 200).\")\n",
        "                return None\n",
        "            else:\n",
        "                # Isso seria um caso inesperado, pois esperamos um erro 404\n",
        "                print(\"\\n--- ERRO: Consulta bem-sucedida com URL errada! ---\\n\")\n",
        "                print(\"Isso não deveria acontecer se a URL errada funcionasse conforme esperado.\")\n",
        "                print(f\"CEP: {data.get('cep')}\")\n",
        "                print(f\"Logradouro: {data.get('logradouro')}\")\n",
        "                print(f\"Bairro: {data.get('bairro')}\")\n",
        "                print(f\"Cidade: {data.get('localidade')}\")\n",
        "                print(f\"Estado: {data.get('uf')}\")\n",
        "                print(\"---------------------------------------------------\")\n",
        "                return data\n",
        "        else:\n",
        "            print(f\"\\n--- ERRO INTENCIONAL PROVOCADO ---\")\n",
        "            print(f\"Erro na requisição. Status code: {response.status_code}. (Esperado: 404 Not Found)\")\n",
        "            print(f\"Motivo: A URL '{url_errada}' está incorreta. Verifique 'wz' no caminho.\")\n",
        "            print(f\"Resposta da API: {response.text}\")\n",
        "            print(\"----------------------------------\")\n",
        "            return None\n",
        "\n",
        "    except requests.exceptions.ConnectionError as e:\n",
        "        print(f\"\\n--- ERRO INTENCIONAL PROVOCADO (Conexão) ---\")\n",
        "        print(f\"Erro de conexão: Não foi possível conectar ao servidor. Verifique sua internet ou a URL. Detalhes: {e}\")\n",
        "        print(f\"Motivo: A URL '{url_errada}' pode estar inacessível ou incorreta.\")\n",
        "        print(\"------------------------------------------\")\n",
        "        return None\n",
        "    except requests.exceptions.Timeout as e:\n",
        "        print(f\"\\n--- ERRO INTENCIONAL PROVOCADO (Timeout) ---\")\n",
        "        print(f\"Erro de timeout: A requisição excedeu o tempo limite. Detalhes: {e}\")\n",
        "        print(f\"Motivo: A URL '{url_errada}' pode estar lenta ou inacessível.\")\n",
        "        print(\"------------------------------------------\")\n",
        "        return None\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"\\n--- ERRO INTENCIONAL PROVOCADO (Geral) ---\")\n",
        "        print(f\"Ocorreu um erro inesperado na requisição: {e}\")\n",
        "        print(f\"Motivo: A URL '{url_errada}' está incorreta, causando uma falha geral.\")\n",
        "        print(\"------------------------------------------\")\n",
        "        return None\n",
        "    except ValueError:\n",
        "        print(f\"\\n--- ERRO DE PARSEAMENTO (Resposta Não JSON) ---\")\n",
        "        print(f\"Erro: A resposta da API não é um JSON válido. Resposta: {response.text}\")\n",
        "        print(f\"Motivo: A URL errada pode ter retornado um HTML de erro ou outro formato.\")\n",
        "        print(\"----------------------------------------------\")\n",
        "        return None\n",
        "\n",
        "# --- Função para consultar com a URL CORRETA (para comparação) ---\n",
        "def consultar_cep_correto(cep):\n",
        "    \"\"\"\n",
        "    Consulta a API ViaCEP para obter informações de endereço (URL CORRETA).\n",
        "\n",
        "    Args:\n",
        "        cep (str): O CEP a ser consultado.\n",
        "\n",
        "    Returns:\n",
        "        dict or None: Um dicionário com os dados do endereço formatados, ou None se ocorrer um erro.\n",
        "    \"\"\"\n",
        "    url_correta = f\"https://viacep.com.br/ws/{cep}/json/\"\n",
        "    print(f\"\\n--- Tentando consultar CEP '{cep}' com a URL CORRETA: {url_correta} ---\")\n",
        "    try:\n",
        "        response = requests.get(url_correta, timeout=5)\n",
        "        response.raise_for_status() # Lança um HTTPError para respostas de status 4xx/5xx\n",
        "        data = response.json()\n",
        "        if data.get('erro'):\n",
        "            print(f\"CEP '{cep}' não encontrado ou inválido na API.\")\n",
        "            return None\n",
        "        else:\n",
        "            print(\"\\n--- Informações de Endereço (Consulta CORRETA) ---\")\n",
        "            print(f\"CEP: {data.get('cep')}\")\n",
        "            print(f\"Logradouro: {data.get('logradouro')}\")\n",
        "            if data.get('complemento'):\n",
        "                print(f\"Complemento: {data.get('complemento')}\")\n",
        "            print(f\"Bairro: {data.get('bairro')}\")\n",
        "            print(f\"Cidade: {data.get('localidade')}\")\n",
        "            print(f\"Estado: {data.get('uf')}\")\n",
        "            if data.get('ddd'):\n",
        "                print(f\"DDD: {data.get('ddd')}\")\n",
        "            print(\"-------------------------------------------------\")\n",
        "            return data\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"Erro ao consultar CEP '{cep}' com a URL correta: {e}\")\n",
        "        return None\n",
        "    except ValueError:\n",
        "        print(f\"Erro: Resposta da API não é um JSON válido ao consultar CEP '{cep}' com a URL correta.\")\n",
        "        return None\n",
        "\n",
        "# --- Exemplo de Uso ---\n",
        "cep_valido = \"01001000\"  # CEP da Praça da Sé, São Paulo\n",
        "cep_invalido = \"99999999\" # Exemplo de CEP que ViaCEP retorna 'erro'\n",
        "\n",
        "# 1. Consulta com erro intencional na URL\n",
        "consultar_cep_com_erro(cep_valido)\n",
        "\n",
        "# 2. Consulta com a URL correta para um CEP válido\n",
        "consultar_cep_correto(cep_valido)\n",
        "\n",
        "# 3. Consulta com a URL correta para um CEP inválido (demonstrando erro da API)\n",
        "consultar_cep_correto(cep_invalido)\n"
      ],
